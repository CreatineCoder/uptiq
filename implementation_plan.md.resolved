## 🚀 Phase 4 — Benchmark Pipeline & Execution

**Duration:** Day 5-6 (6-8 hours)

### 4.1 Pipeline Architecture

```mermaid
sequenceDiagram
    participant Runner as Benchmark Runner
    participant DS as Dataset
    participant A1 as Naive RAG
    participant A2 as CRAG
    participant Eval as Evaluator
    participant Store as Result Store

    Runner->>DS: Load 1,500 queries
    loop For each query
        Runner->>A1: Send query
        A1-->>Runner: AgentResponse (answer, context, latency, cost)
        Runner->>A2: Send query
        A2-->>Runner: AgentResponse (answer, context, latency, cost)
        Runner->>Store: Save both responses
    end
    Runner->>Eval: Run quantitative metrics
    Runner->>Eval: Run RAGAS evaluation
    Runner->>Eval: Run LLM-as-a-Judge (sampled 200 queries)
    Eval-->>Store: Save all scores
    Runner->>Store: Generate final report
```

### 4.2 Benchmark Runner — `benchmark_runner.py`

```python
class BenchmarkRunner:
    """
    Main orchestrator: Run → Collect → Evaluate → Compare
    Implements checkpointing for long runs.
    """

    def __init__(self, config_path: str):
        self.config = load_config(config_path)
        self.agents = {
            "naive_rag": NaiveRAGAgent(self.config.naive_rag),
            "corrective_rag": CorrectiveRAGAgent(self.config.corrective_rag)
        }
        self.dataset = DatasetLoader(self.config.dataset).load()
        self.result_collector = ResultCollector(self.config.output_dir)
        self.evaluator_quantitative = QuantitativeEvaluator()
        self.evaluator_ragas = RagasEvaluator()
        self.evaluator_llm_judge = LLMJudge()

    def run(self):
        """Execute full benchmark pipeline"""
        print(f"🚀 Starting benchmark with {len(self.dataset)} queries...")

        # Phase 1: Run agents
        for i, query_item in enumerate(tqdm(self.dataset)):
            # Checkpoint: skip already processed
            if self.result_collector.is_processed(query_item["id"]):
                continue

            results = {}
            for agent_name, agent in self.agents.items():
                try:
                    response = agent.answer(query_item["question"])
                    results[agent_name] = {
                        "question": query_item["question"],
                        "gold_answer": query_item["gold_answer"],
                        "predicted_answer": response.answer,
                        "retrieved_contexts": response.retrieved_contexts,
                        "latency": response.latency,
                        "token_usage": response.token_usage,
                        "steps": response.steps,
                        "agent_type": response.agent_type
                    }
                except Exception as e:
                    results[agent_name] = {"error": str(e), "agent_type": agent_name}

            # Save checkpoint
            self.result_collector.save(query_item["id"], results)

            # Rate limiting
            time.sleep(0.5)

        # Phase 2: Evaluate
        print("📊 Running evaluation...")
        all_results = self.result_collector.load_all()

        # Quantitative
        quant_scores = self.evaluator_quantitative.evaluate(all_results)

        # RAGAS (batch)
        for agent_name in self.agents:
            agent_results = [r[agent_name] for r in all_results if agent_name in r]
            ragas_scores = self.evaluator_ragas.evaluate_batch(agent_results)
            self.result_collector.save_scores(agent_name, "ragas", ragas_scores)

        # LLM Judge (sample 200 for cost efficiency)
        sample = random.sample(all_results, min(200, len(all_results)))
        for item in tqdm(sample, desc="LLM Judge"):
            for agent_name in self.agents:
                if agent_name in item and "error" not in item[agent_name]:
                    judge_scores = self.evaluator_llm_judge.evaluate(
                        question=item[agent_name]["question"],
                        gold_answer=item[agent_name]["gold_answer"],
                        predicted_answer=item[agent_name]["predicted_answer"],
                        context="\n".join(item[agent_name]["retrieved_contexts"])
                    )
                    self.result_collector.save_judge_score(
                        item[agent_name]["question"], agent_name, judge_scores
                    )

        print("✅ Benchmark complete!")
```

